{
  "name": "surreal-zod",
  "version": "0.1.0-alpha.0",
  "description": "Author SurrealDB schemas with Zod — sz.* drop-in, SurrealQL DDL generation, and JS<->DB codecs.",
  "type": "module",
  "module": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib",
    "src"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "prepack": "bun run build",
    "test": "bun test",
    "test:unit": "bun test test/unit",
    "test:live": "bun test test/live",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "surrealdb": "^2.0.3",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/bun": "latest",
    "surrealdb": "^2.0.3",
    "tsup": "^8",
    "typescript": "^5",
    "zod": "^4.3.5"
  }
}
