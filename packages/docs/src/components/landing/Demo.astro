---
// Token color classes (brand code tokens)
const kw = "text-code-keyword";
const fn = "text-code-fn";
const ty = "text-code-type";
const st = "text-code-string";
const pl = "text-code-plain";
const vr = "text-pink";
const cm = "text-code-comment";
const mut = "text-ink-3";
const ok = "text-success";

type Tok = { t: string; c: string };
type Line = { num: number | null; hl?: boolean; tokens: Tok[] };

const tsLines: Line[] = [
  { num: 1, tokens: [{ t: "export ", c: kw }, { t: "const ", c: kw }, { t: "User", c: ty }, { t: " = ", c: pl }, { t: "defineTable", c: fn }, { t: "(", c: pl }, { t: '"user"', c: st }, { t: ", {", c: pl }] },
  { num: 2, tokens: [{ t: "  id", c: pl }, { t: ": ", c: pl }, { t: "sz", c: pl }, { t: ".", c: pl }, { t: "string", c: fn }, { t: "(),", c: pl }] },
  { num: 3, hl: true, tokens: [{ t: "  email", c: pl }, { t: ": ", c: pl }, { t: "sz", c: pl }, { t: ".", c: pl }, { t: "email", c: fn }, { t: "().", c: pl }, { t: "unique", c: fn }, { t: "(),", c: pl }] },
  { num: 4, tokens: [{ t: "  name", c: pl }, { t: ": ", c: pl }, { t: "sz", c: pl }, { t: ".", c: pl }, { t: "string", c: fn }, { t: "().", c: pl }, { t: "optional", c: fn }, { t: "(),", c: pl }] },
  { num: 5, tokens: [{ t: "  createdAt", c: pl }, { t: ": ", c: pl }, { t: "sz", c: pl }, { t: ".", c: pl }, { t: "datetime", c: fn }, { t: "()", c: pl }] },
  { num: 6, tokens: [{ t: "    .", c: pl }, { t: "$default", c: fn }, { t: "(", c: pl }, { t: "surql", c: fn }, { t: "`", c: st }, { t: "time::now", c: fn }, { t: "()", c: pl }, { t: "`", c: st }, { t: ")", c: pl }] },
  { num: 7, tokens: [{ t: "    .", c: pl }, { t: "$readonly", c: fn }, { t: "(),", c: pl }] },
  { num: 8, tokens: [{ t: "});", c: pl }] },
];

const surqlLines: Line[] = [
  { num: 1, tokens: [{ t: "DEFINE TABLE ", c: kw }, { t: "user ", c: ty }, { t: "TYPE NORMAL SCHEMAFULL", c: kw }, { t: ";", c: pl }] },
  { num: 2, hl: true, tokens: [{ t: "DEFINE FIELD ", c: kw }, { t: "email ", c: pl }, { t: "ON TABLE ", c: kw }, { t: "user ", c: ty }, { t: "TYPE ", c: kw }, { t: "string", c: ty }] },
  { num: null, hl: true, tokens: [{ t: "  ASSERT ", c: kw }, { t: "string::is_email", c: fn }, { t: "(", c: pl }, { t: "$value", c: vr }, { t: ");", c: pl }] },
  { num: 3, hl: true, tokens: [{ t: "DEFINE INDEX ", c: kw }, { t: "user_email_idx ", c: pl }, { t: "ON TABLE ", c: kw }, { t: "user", c: ty }] },
  { num: null, hl: true, tokens: [{ t: "  FIELDS ", c: kw }, { t: "email ", c: pl }, { t: "UNIQUE", c: kw }, { t: ";", c: pl }] },
  { num: 4, tokens: [{ t: "DEFINE FIELD ", c: kw }, { t: "name ", c: pl }, { t: "ON TABLE ", c: kw }, { t: "user ", c: ty }, { t: "TYPE ", c: kw }, { t: "option", c: kw }, { t: "<", c: pl }, { t: "string", c: ty }, { t: ">;", c: pl }] },
  { num: 5, tokens: [{ t: "DEFINE FIELD ", c: kw }, { t: "createdAt ", c: pl }, { t: "ON TABLE ", c: kw }, { t: "user ", c: ty }, { t: "TYPE ", c: kw }, { t: "datetime", c: ty }] },
  { num: null, tokens: [{ t: "  DEFAULT ", c: kw }, { t: "time::now", c: fn }, { t: "() ", c: pl }, { t: "READONLY", c: kw }, { t: ";", c: pl }] },
];

const termLines = [
  { sym: "$", symC: mut, msg: " sz generate add_users", msgC: "text-code-plain" },
  { sym: "-", symC: mut, msg: " planning migration against live schema...", msgC: mut },
  { sym: "+", symC: ok, msg: " DEFINE TABLE user TYPE NORMAL SCHEMAFULL", msgC: ok },
  { sym: "+", symC: ok, msg: " DEFINE FIELD email ON TABLE user ... ASSERT string::is_email", msgC: ok },
  { sym: "+", symC: ok, msg: " DEFINE INDEX user_email_idx ON TABLE user FIELDS email UNIQUE", msgC: ok },
  { sym: "✓", symC: ok, msg: " wrote migrations/0001_add_users.surql", msgC: "text-ink-2" },
];

// --- Migrations (CLI) state ---
const migrationsLines = [
  { sym: "$", symC: "text-pink", msg: " sz generate add_users", msgC: "text-code-plain" },
  { sym: "~", symC: mut, msg: " diffing schema.ts against snapshot…", msgC: mut },
  { sym: "+", symC: ok, msg: " DEFINE TABLE user TYPE NORMAL SCHEMAFULL", msgC: ok },
  { sym: "+", symC: ok, msg: " DEFINE FIELD email ON TABLE user … UNIQUE", msgC: ok },
  { sym: "✓", symC: ok, msg: " wrote migrations/0001_add_users.surql", msgC: "text-ink-2" },
  { sym: " ", symC: mut, msg: "", msgC: mut },
  { sym: "$", symC: "text-pink", msg: " sz migrate", msgC: "text-code-plain" },
  { sym: "▸", symC: "text-soft", msg: " applying 0001_add_users.surql → surrealdb", msgC: "text-soft" },
  { sym: "✓", symC: ok, msg: " migrated user · 3 fields · 1 index", msgC: "text-ink-2" },
  { sym: "✓", symC: ok, msg: " recorded 0001 · sha 9f2c… · up to date", msgC: ok },
];

// --- End-to-end types state ---
const typesLines: Line[] = [
  { num: 1, tokens: [{ t: "const ", c: kw }, { t: "limit ", c: pl }, { t: "= ", c: pl }, { t: "20", c: ty }] },
  { num: 2, tokens: [{ t: " ", c: pl }] },
  { num: 3, tokens: [{ t: "const ", c: kw }, { t: "rows ", c: pl }, { t: "= ", c: pl }, { t: "await ", c: kw }, { t: "db", c: pl }, { t: ".", c: pl }, { t: "query", c: fn }, { t: "<[", c: pl }, { t: "unknown", c: ty }, { t: "[]]>(", c: pl }, { t: "surql", c: fn }, { t: "`", c: st }] },
  { num: 4, tokens: [{ t: "  SELECT ", c: kw }, { t: "* ", c: pl }, { t: "FROM ", c: kw }, { t: "user", c: ty }] },
  { num: 5, tokens: [{ t: "  WHERE ", c: kw }, { t: "createdAt ", c: pl }, { t: "> ", c: pl }, { t: "time::now", c: fn }, { t: "() ", c: pl }, { t: "- ", c: pl }, { t: "90d", c: ty }] },
  { num: 6, tokens: [{ t: "  ORDER BY ", c: kw }, { t: "createdAt ", c: pl }, { t: "DESC ", c: kw }, { t: "LIMIT ", c: kw }, { t: "${", c: pl }, { t: "limit", c: vr }, { t: "}", c: pl }] },
  { num: 7, tokens: [{ t: "`", c: st }, { t: ")", c: pl }] },
  { num: 8, tokens: [{ t: " ", c: pl }] },
  { num: 9, tokens: [{ t: "const ", c: kw }, { t: "users ", c: pl }, { t: "= ", c: pl }, { t: "rows", c: pl }, { t: "[", c: pl }, { t: "0", c: ty }, { t: "].", c: pl }, { t: "map", c: fn }, { t: "(", c: pl }, { t: "User", c: ty }, { t: ".", c: pl }, { t: "decode", c: fn }, { t: ")", c: pl }] },
  { num: 10, tokens: [{ t: "users", c: pl }, { t: "[", c: pl }, { t: "0", c: ty }, { t: "].", c: pl }] },
];
const typeMembers = [
  { name: "id", type: 'RecordId<"user", string>' },
  { name: "email", type: "string" },
  { name: "name?", type: "string" },
  { name: "createdAt", type: "Date" },
];

// --- Live round-trip state ---
const driftLines: { c: string; tokens: Tok[] }[] = [
  { c: pl, tokens: [{ t: "ON TABLE ", c: kw }, { t: "user", c: ty }] },
  { c: ok, tokens: [{ t: "+ ", c: ok }, { t: "ASSERT ", c: kw }, { t: "string::is_email", c: fn }, { t: "($value)", c: pl }, { t: "   email", c: mut }] },
  { c: vr, tokens: [{ t: "~ ", c: vr }, { t: "TYPE ", c: kw }, { t: "option<string> ", c: ty }, { t: "→ ", c: pl }, { t: "string", c: ty }, { t: "   name", c: mut }] },
  { c: "text-danger", tokens: [{ t: "- ", c: "text-danger" }, { t: "DEFINE INDEX ", c: kw }, { t: "legacy_email_idx", c: pl }, { t: "   removed", c: mut }] },
];

const icons: Record<string, string> = {
  file: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/>',
  terminal: '<path d="m4 17 6-6-6-6"/><path d="M12 19h8"/>',
  braces: '<path d="M8 3H7a2 2 0 0 0-2 2v5a2 2 0 0 1-2 2 2 2 0 0 1 2 2v5a2 2 0 0 0 2 2h1"/><path d="M16 3h1a2 2 0 0 1 2 2v5a2 2 0 0 1 2 2 2 2 0 0 1-2 2v5a2 2 0 0 1-2 2h-1"/>',
  repeat: '<path d="m17 2 4 4-4 4"/><path d="M3 11v-1a4 4 0 0 1 4-4h14"/><path d="m7 22-4-4 4-4"/><path d="M21 13v1a4 4 0 0 1-4 4H3"/>',
};

const rail = [
  { id: "schema", label: "Schema → DDL", icon: "file" },
  { id: "migrations", label: "Migrations (CLI)", icon: "terminal" },
  { id: "types", label: "End-to-end types", icon: "braces" },
  { id: "live", label: "Live round-trip", icon: "repeat" },
];

const tabHead: Record<string, { l: string; lt: string; r?: string; rt?: string }> = {
  schema: { l: "schema.ts", lt: "TypeScript", r: "user.surql", rt: "SurrealQL" },
  migrations: { l: "terminal", lt: "sz migrate" },
  types: { l: "query.ts", lt: "TypeScript" },
  live: { l: "sz diff --live", lt: "drift" },
};
---

<section id="demo" class="relative px-6 py-24 sm:py-28">
  <div class="mx-auto max-w-6xl">
    <!-- header -->
    <div class="text-center">
      <p class="font-mono text-xs uppercase tracking-[0.22em] text-ink-3">
        // schema in, surrealql out
      </p>
      <h2
        class="mx-auto mt-4 max-w-2xl font-display text-3xl font-semibold tracking-tight text-balance text-ink-2 sm:text-4xl"
      >
        From <code class="font-mono text-soft">sz.*</code> schema to generated{" "}
        <span
          class="bg-gradient-to-r from-purple to-pink bg-clip-text text-transparent"
          >SurrealQL</span
        >.
      </h2>
    </div>

    <!-- window -->
    <div
      data-demo
      class="mt-12 overflow-hidden rounded-2xl border border-border bg-surface shadow-[0_30px_80px_-30px_rgba(0,0,0,0.8)]"
    >
      <div class="flex">
        <!-- capabilities rail -->
        <aside
          class="hidden w-56 shrink-0 border-r border-border-subtle bg-canvas-2 p-3 lg:block"
        >
          <p
            class="px-2 pt-1 font-mono text-[10px] uppercase tracking-[0.16em] text-ink-3"
          >
            Capabilities
          </p>
          <nav class="mt-3 flex flex-col gap-1">
            {
              rail.map((item, i) => (
                <button
                  type="button"
                  data-demo-tab={item.id}
                  data-active={i === 0 ? "true" : "false"}
                  class="group flex items-center gap-2.5 rounded-lg px-2.5 py-2 text-left text-sm text-ink-2 transition-colors hover:text-ink data-[active=true]:bg-surface-2 data-[active=true]:text-ink data-[active=true]:shadow-[inset_2px_0_0_0_var(--color-purple)]"
                >
                  <svg
                    class="size-4 shrink-0 text-ink-3 group-data-[active=true]:text-soft"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    set:html={icons[item.icon]}
                  />
                  {item.label}
                </button>
              ))
            }
          </nav>
        </aside>

        <!-- editor column -->
        <div class="min-w-0 flex-1">
          <!-- window header -->
          <div
            class="flex items-center justify-between border-b border-border-subtle px-4 py-3"
          >
            <div class="flex items-center gap-1.5">
              <span class="size-3 rounded-full bg-[#ff5f57]"></span>
              <span class="size-3 rounded-full bg-[#febc2e]"></span>
              <span class="size-3 rounded-full bg-[#28c840]"></span>
            </div>
            <span class="font-mono text-xs text-ink-3">surreal-zod</span>
            <span
              class="inline-flex items-center gap-1.5 rounded-md border border-purple/40 bg-purple/10 px-2.5 py-1 font-mono text-[11px] text-soft"
            >
              <svg class="size-2.5" viewBox="0 0 24 24" fill="currentColor"
                ><path d="M8 5v14l11-7z"></path></svg
              >
              sz generate
            </span>
          </div>

          <!-- ============ STATE: schema -> DDL ============ -->
          <div data-demo-panel="schema">
            <!-- panes: side-by-side w/ bare seam arrow on desktop, stacked on mobile -->
            <div class="relative grid lg:grid-cols-2">
              <!-- left pane -->
              <div
                class="flex min-w-0 flex-col border-b border-border-subtle lg:border-b-0"
              >
                <div
                  class="flex items-center justify-between border-b border-border-subtle px-4 py-2.5"
                >
                  <span class="font-mono text-xs text-ink">{tabHead.schema.l}</span>
                  <span class="font-mono text-[11px] text-ink-3">{tabHead.schema.lt}</span>
                </div>
                <div
                  class="min-w-0 overflow-x-auto bg-code-bg py-4 font-mono text-[13px] leading-6"
                >
                  {
                    tsLines.map((line) => (
                      <div
                        class:list={[
                          "flex border-l-2 pr-4",
                          line.hl ? "border-purple bg-purple/10" : "border-transparent",
                        ]}
                      >
                        <span class="w-10 shrink-0 select-none pr-3 text-right text-ink-3">
                          {line.num}
                        </span>
                        <code class="whitespace-pre">
                          {line.tokens.map((tk) => (
                            <span class={tk.c}>{tk.t}</span>
                          ))}
                        </code>
                      </div>
                    ))
                  }
                </div>
              </div>
              <!-- right pane -->
              <div class="flex min-w-0 flex-col">
                <div
                  class="flex items-center justify-between border-b border-border-subtle bg-pink/[0.03] px-4 py-2.5"
                >
                  <span class="font-mono text-xs text-ink">{tabHead.schema.r}</span>
                  <span class="font-mono text-[11px] text-ink-3">{tabHead.schema.rt}</span>
                </div>
                <div
                  class="relative min-w-0 overflow-x-auto bg-code-bg py-4 font-mono text-[13px] leading-6"
                >
                  <div
                    class="pointer-events-none absolute inset-0 bg-gradient-to-r from-transparent to-pink/[0.04]"
                  >
                  </div>
                  {
                    surqlLines.map((line) => (
                      <div
                        class:list={[
                          "relative flex border-l-2 pr-4",
                          line.hl ? "border-purple bg-purple/10" : "border-transparent",
                        ]}
                      >
                        <span class="w-10 shrink-0 select-none pr-3 text-right text-ink-3">
                          {line.num}
                        </span>
                        <code class="whitespace-pre">
                          {line.tokens.map((tk) => (
                            <span class={tk.c}>{tk.t}</span>
                          ))}
                        </code>
                      </div>
                    ))
                  }
                </div>
              </div>
              <!-- bare seam arrow (desktop only) -->
              <div
                class="absolute left-1/2 top-5 hidden -translate-x-1/2 -translate-y-1/2 px-2 text-soft lg:block"
              >
                <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m13 6 6 6-6 6"></path></svg>
              </div>
            </div>

            <!-- map note -->
            <div
              class="flex items-center gap-2 border-y border-border-subtle bg-purple/10 px-4 py-2.5 text-xs text-ink-2"
            >
              <span class="size-1.5 shrink-0 rounded-full bg-gradient-to-r from-purple to-pink"></span>
              <span>
                Highlighted — one <code class="font-mono text-soft">sz.email().unique()</code>
                compiles to a typed <code class="font-mono text-code-type">FIELD</code> + a
                <code class="font-mono text-code-type">UNIQUE INDEX</code>.
              </span>
            </div>

            <!-- terminal -->
            <div class="bg-code-bg px-4 py-3.5 font-mono text-xs leading-6">
              {
                termLines.map((l) => (
                  <div class="whitespace-pre">
                    <span class={l.symC}>{l.sym}</span>
                    <span class={l.msgC}>{l.msg}</span>
                  </div>
                ))
              }
            </div>
          </div>

          <!-- ============ STATE: migrations ============ -->
          <div data-demo-panel="migrations" hidden>
            <div
              class="flex items-center justify-between border-b border-border-subtle px-4 py-2.5"
            >
              <span class="font-mono text-xs text-ink">{tabHead.migrations.l}</span>
              <span class="font-mono text-[11px] text-ink-3">{tabHead.migrations.lt}</span>
            </div>
            <div class="bg-code-bg px-4 py-4 font-mono text-[13px] leading-[1.7]">
              {
                migrationsLines.map((l) => (
                  <div class="whitespace-pre">
                    <span class={l.symC}>{l.sym}</span>
                    <span class={l.msgC}>{l.msg}</span>
                  </div>
                ))
              }
            </div>
            <div
              class="flex items-center gap-2 border-t border-border-subtle bg-purple/10 px-4 py-2.5 text-xs text-ink-2"
            >
              <span class="size-1.5 shrink-0 rounded-full bg-gradient-to-r from-purple to-pink"></span>
              <span>Every change is a reviewable up/down migration — applied in order, recorded by sha.</span>
            </div>
          </div>

          <!-- ============ STATE: end-to-end types ============ -->
          <div data-demo-panel="types" hidden>
            <div
              class="flex items-center justify-between border-b border-border-subtle px-4 py-2.5"
            >
              <span class="font-mono text-xs text-ink">{tabHead.types.l}</span>
              <span class="font-mono text-[11px] text-ink-3">{tabHead.types.lt}</span>
            </div>
            <div class="relative bg-code-bg px-4 py-4 font-mono text-[13px] leading-6">
              {
                typesLines.map((line) => (
                  <div class="flex whitespace-pre">
                    <span class="w-8 shrink-0 select-none pr-3 text-right text-ink-3">{line.num}</span>
                    <code class="whitespace-pre">
                      {line.tokens.map((tk) => (
                        <span class={tk.c}>{tk.t}</span>
                      ))}
                    </code>
                  </div>
                ))
              }
              <!-- autocomplete dropdown -->
              <div
                class="ml-[3.7rem] mt-1 w-fit overflow-hidden rounded-lg border border-border bg-surface-2 text-[12.5px] shadow-[0_16px_40px_-12px_rgba(0,0,0,0.7)]"
              >
                {
                  typeMembers.map((m, i) => (
                    <div
                      class:list={[
                        "flex items-center gap-3 px-3 py-1.5",
                        i === 0 && "bg-purple/15",
                      ]}
                    >
                      <span class="text-code-fn">{m.name}</span>
                      <span class="text-ink-3">:</span>
                      <span class="text-code-type">{m.type}</span>
                    </div>
                  ))
                }
              </div>
            </div>
            <div
              class="flex items-center gap-2 border-t border-border-subtle bg-purple/10 px-4 py-2.5 text-xs text-ink-2"
            >
              <span class="size-1.5 shrink-0 rounded-full bg-gradient-to-r from-purple to-pink"></span>
              <span>Decoded rows are fully typed — <code class="font-mono text-soft">datetime → Date</code>, <code class="font-mono text-soft">RecordId</code>, optionals and all.</span>
            </div>
          </div>

          <!-- ============ STATE: live round-trip ============ -->
          <div data-demo-panel="live" hidden>
            <div
              class="flex items-center justify-between border-b border-border-subtle px-4 py-2.5"
            >
              <span class="font-mono text-xs text-ink">{tabHead.live.l}</span>
              <span class="font-mono text-[11px] text-ink-3">{tabHead.live.lt}</span>
            </div>
            <div class="bg-code-bg px-4 py-4 font-mono text-[13px] leading-[1.7]">
              <div class="whitespace-pre text-ink-3">
                <span class="text-pink">$</span> sz diff --live
              </div>
              <div class="mb-2 whitespace-pre text-ink-3">~ comparing schema.ts ↔ running database</div>
              {
                driftLines.map((line) => (
                  <div class="whitespace-pre pl-2">
                    {line.tokens.map((tk) => (
                      <span class={tk.c}>{tk.t}</span>
                    ))}
                  </div>
                ))
              }
              <div class="mt-2 whitespace-pre text-ink-2">3 changes · run <span class="text-soft">sz sync</span> to reconcile</div>
            </div>
            <div
              class="flex items-center gap-2 border-t border-border-subtle bg-purple/10 px-4 py-2.5 text-xs text-ink-2"
            >
              <span class="size-1.5 shrink-0 rounded-full bg-gradient-to-r from-purple to-pink"></span>
              <span>Diff your code against the live database — normalized through SurrealDB, so there is no formatting noise.</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- footer row -->
    <div class="mt-6 flex flex-col items-center justify-between gap-4 sm:flex-row">
      <p class="text-sm text-ink-2">
        Define your tables and fields in TypeScript — the SurrealQL DDL is
        generated for you.
      </p>
      <a
        href="/getting-started"
        class="inline-flex shrink-0 items-center gap-2 rounded-xl border border-border bg-surface px-5 py-2.5 text-sm font-medium text-ink transition-colors hover:border-ink-3"
      >
        Open the playground
        <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </div>
</section>

<script>
  for (const root of document.querySelectorAll<HTMLElement>("[data-demo]")) {
    const tabs = root.querySelectorAll<HTMLElement>("[data-demo-tab]");
    const panels = root.querySelectorAll<HTMLElement>("[data-demo-panel]");
    for (const tab of tabs) {
      tab.addEventListener("click", () => {
        const id = tab.getAttribute("data-demo-tab");
        for (const t of tabs)
          t.setAttribute("data-active", String(t === tab));
        for (const p of panels)
          p.toggleAttribute("hidden", p.getAttribute("data-demo-panel") !== id);
      });
    }
  }
</script>
