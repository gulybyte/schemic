                  "name": "Lead",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Author your SurrealDB tables as Zod schemas. sz.* is a 1:1 drop-in for z.* (same constructors, same chaining) so a table is just an object schema.",
                  "lineHeight": 1.55,
                  "fontFamily": "Geist",
                  "fontSize": 17,
                  "fontWeight": "normal"
                },
                {
                  "type": "frame",
