{
  "_meta": {
    "name": "Reverie design tokens",
    "description": "Single source of truth for Reverie design tokens (Studio app + docs website). Authoritative values mirror the variable names used in the .pen files so design and code stay in sync.",
    "canonicalUiSource": "design/app.pen",
    "owner": "designer (design-system/tokens)",
    "consumers": ["design/app.pen", "design/website.pen", "packages/studio"],
    "status": {
      "authoritative": "Exact token set defined as .pen variables. Do not change names without coordinating.",
      "derived": "Radii, shadows, spacing, and font-size scales observed from component usage and proposed for ratification — not yet formal .pen variables."
    }
  },

  "color": {
    "brand": {
      "accent-purple": "#9600ff",
      "accent-hot": "#ff00a0",
      "accent-pink": "#ff85d6",
      "accent-soft": "#c77dff"
    },
    "surface": {
      "canvas": "#0e0c14",
      "canvas-2": "#13101c",
      "surface": "#16131f",
      "surface-2": "#1c1826",
      "code-bg": "#100d18"
    },
    "border": {
      "border": "#2a2438",
      "border-subtle": "#211b2d"
    },
    "text": {
      "text-primary": "#f5f3fa",
      "text-secondary": "#aaa1bb",
      "text-muted": "#6f6781"
    },
    "status": {
      "success-green": "#46d39a",
      "warning-amber": "#ffb454",
      "danger-red": "#ff5d6c"
    },
    "code": {
      "code-keyword": "#c77dff",
      "code-fn": "#7bd0ff",
      "code-type": "#9fe3b0",
      "code-string": "#ff85d6",
      "code-plain": "#d8d3e4",
      "code-comment": "#5d5670"
    },
    "light": {
