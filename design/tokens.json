  "typography": {
    "family": {
      "font-display": "Geist",
      "font-mono": "JetBrains Mono"
    },
    "familyBlueprint": {
      "bp-font-display": "Anton",
      "bp-font-body": "Funnel Sans",
      "bp-font-mono": "IBM Plex Mono"
    }
  },

  "layout": {
    "gutter": 64,
    "section-y": 100,
    "maxw-card": 1040
  },

  "derived": {
    "_note": "Observed from component usage; proposed scales, not yet formal .pen variables. Ratify before formalizing.",
    "radius": {
      "xs": 5,
      "sm": 6,
      "md": 8,
      "lg": 10,
      "xl": 12,
      "2xl": 14,
      "3xl": 16
    },
    "fontSize": {
      "micro": 10,
      "tiny": 11,
      "small": 12,
      "body": 13,
      "base": 14,
      "lg": 16,
      "xl": 19,
      "2xl": 24
    },
    "shadow": {
      "popover": { "offsetY": 14, "blur": 40, "color": "#000000aa" },
      "modal": { "offsetY": 20, "blur": 60, "color": "#000000aa" }
    }
  }
}
