      "light-surface": "#ffffff",
      "light-border": "#e6e1f0",
      "light-text": "#171221",
      "light-text-muted": "#6a6379"
    }
  },

  "colorBlueprint": {
    "_note": "bp-* alternate (light/blueprint) palette.",
    "bp-canvas": "#FFFFFF",
    "bp-canvas-2": "#F4F5F7",
    "bp-code-bg": "#F0F2F5",
    "bp-border": "#D0D5DA",
    "bp-border-dark": "#1A1A1A",
    "bp-text-primary": "#1A1A1A",
    "bp-text-secondary": "#555555",
    "bp-text-muted": "#888888",
    "bp-accent": "#4A9FD8",
    "bp-accent-dark": "#2B7DB3",
    "bp-accent-soft": "#D6ECFB",
    "bp-success": "#27AE60",
    "bp-warning": "#B7791F",
    "bp-danger": "#C0392B",
    "bp-code-keyword": "#2B7DB3",
    "bp-code-string": "#C0392B",
    "bp-code-type": "#27AE60",
    "bp-code-comment": "#888888"
